model Candidate_profile {
  id           String    @id @default(uuid())
  userId       String    @unique @map("user_id")
  headline     String?
  summary      String?   @db.Text
  phone        String?
  address      String?
  city         String?
  dateOfBirth  DateTime? @map("date_of_birth")
  gender       String?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Relations
  user        User              @relation("UserToCandidateProfile", fields: [userId], references: [id], onDelete: Cascade)
  experiences Experience[]      @relation("CandidateProfileToExperience")
  educations  Education[]       @relation("CandidateProfileToEducation")
  skills      Candidate_skill[] @relation("CandidateProfileToCandidateSkill")

  @@index([userId])
  @@map("candidate_profiles")
}

model Candidate_skill {
  profileId String @map("profile_id")
  skillId   String @map("skill_id")

  profile Candidate_profile @relation("CandidateProfileToCandidateSkill", fields: [profileId], references: [id], onDelete: Cascade)
  skill   Skill             @relation("SkillToCandidateSkill", fields: [skillId], references: [id], onDelete: Cascade)

  @@id([profileId, skillId])
  @@index([profileId, skillId])
  @@map("candidate_skills")
}

model Experience {
  id          String   @id @default(uuid())
  profileId   String   @map("profile_id")
  title       String
  company     String
  startDate   DateTime @map("start_date")
  endDate     DateTime? @map("end_date")
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  profile Candidate_profile @relation("CandidateProfileToExperience", fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@map("experiences")
}

model Education {
  id        String   @id @default(uuid())
  profileId String   @map("profile_id")
  school    String
  degree    String
  field     String?
  startDate DateTime @map("start_date")
  endDate   DateTime? @map("end_date")
  createdAt DateTime @default(now()) @map("created_at")

  profile Candidate_profile @relation("CandidateProfileToEducation", fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@map("education")
}
