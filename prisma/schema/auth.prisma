model User {
  id             String    @id @default(uuid())
  email          String    @unique
  password       String
  fullName       String?   @map("full_name")
  role           String    @default("candidate")
  avatarUrl      String?   @map("avatar_url")
  phone          String    @unique
  refreshToken   String?   @db.Text @map("refresh_token")
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  // Relations - 1:1
  candidateProfile Candidate_profile?  @relation("UserToCandidateProfile")
  companyProfile   Company?           @relation("UserToCompany")
  // Relations - 1:N
  resumes          Resume[]           @relation("UserToResume")
  applications     Application[]      @relation("UserToApplication")
  bookmarks        Bookmark[]         @relation("UserToBookmark")

  @@map("users")
}
