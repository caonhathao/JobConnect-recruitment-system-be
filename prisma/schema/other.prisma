model Resume {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  title      String
  fileUrl    String   @map("file_url")
  isDefault  Boolean  @default(false) @map("is_default")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relations
  user User @relation("UserToResume", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("resumes")
}

model Application {
  id            String   @id @default(uuid())
  jobId         String   @map("job_id")
  userId        String   @map("user_id")
  companyId     String?  @map("company_id")
  fullName      String   @map("full_name")
  email         String
  phone         String
  resumeUrl     String   @map("resume_url")
  coverLetter   String?  @db.Text @map("cover_letter")
  status        String   @default("pending")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  job     Job      @relation("JobToApplication", fields: [jobId], references: [id])
  user    User     @relation("UserToApplication", fields: [userId], references: [id])
  company Company? @relation("ApplicationToCompany", fields: [companyId], references: [id])

  @@index([jobId, userId])
  @@map("applications")
}

model Bookmark {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  jobId     String   @map("job_id")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation("UserToBookmark", fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation("JobToBookmark", fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([userId, jobId])
  @@map("bookmarks")
}
