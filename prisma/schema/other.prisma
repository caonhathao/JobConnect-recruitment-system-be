model Resume {
  id           String        @id @default(uuid()) @db.Uuid
  userId       String        @map("user_id") @db.Uuid
  title        String
  fileUrl      String        @map("file_url")
  isDefault    Boolean       @default(false) @map("is_default")
  vectorStatus VECTOR_STATUS @default(PENDING) @map("vector_status")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user          User            @relation("UserToResume", fields: [userId], references: [id], onDelete: Cascade)
  resumeVectors ResumeVectors[] @relation("ResumeToExperience")

  @@index([userId])
  @@map("resumes")
}

model Application {
  id          String   @id @default(uuid()) @db.Uuid
  jobId       String   @map("job_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  companyId   String?  @map("company_id") @db.Uuid
  fullName    String   @map("full_name")
  email       String
  phone       String
  resumeUrl   String   @map("resume_url")
  coverLetter String?  @map("cover_letter") @db.Text
  status      String   @default("pending")
  isDeleted   Boolean  @default(false) @map("is_deleted")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  job     Job      @relation("JobToApplication", fields: [jobId], references: [id])
  user    User     @relation("UserToApplication", fields: [userId], references: [id])
  company Company? @relation("ApplicationToCompany", fields: [companyId], references: [id])

  @@index([jobId, userId])
  @@map("applications")
}

model Bookmark {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  jobId     String   @map("job_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation("UserToBookmark", fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation("JobToBookmark", fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([userId, jobId])
  @@map("bookmarks")
}
