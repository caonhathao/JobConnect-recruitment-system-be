								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "DELETE",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{accessToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/resumes/{{resumeId}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "resumes", "{{resumeId}}"]
						}
					}
				}
			]
		},
		{
			"name": "🤖 RAG Chat (Core Feature)",
			"description": "AI-powered job assistant using RAG pipeline: intent classification → vector search → Ollama Qwen2.5 response. All requests require a processed CV (vectorStatus = COMPLETED) for Group 2/3 queries.",
			"item": [
				{
					"name": "Chat - Group 1: Job Search",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// =============================================",
									"// Status Code Check",
									"// =============================================",
									"pm.test('Status 200 - OK', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"// =============================================",
									"// Response Time Check (AI tasks: allow < 15000ms)",
									"// Ollama + HuggingFace API calls = slower than normal API",
									"// =============================================",
									"pm.test('Response time < 15000ms (AI generation)', function () {",
									"    pm.expect(pm.response.responseTime).to.be.below(15000);",
									"});",
									"",
									"// =============================================",
									"// Validate AI Response is NOT null/empty",
									"// =============================================",
									"pm.test('AI response (ans) is not null or empty', function () {",
									"    const json = pm.response.json();",
									"    pm.expect(json).to.have.property('ans');",
									"    pm.expect(json.ans).to.not.be.null;",
									"    pm.expect(json.ans).to.not.be.empty;",
									"    console.log('[Chat] AI response length: ' + json.ans.length + ' chars');",
									"    console.log('[Chat] Response preview: ' + json.ans.substring(0, 120) + '...');",
									"});",
									"",
									"// =============================================",
									"// CRITICAL LOGIC CHECK: NaN / Double Brackets",
									"// =============================================",
									"if (pm.response.code === 500) {",
									"    const errJson = pm.response.json();",
									"    const errMsg = JSON.stringify(errJson).toLowerCase();",
									"    ",
									"    if (errMsg.includes('input syntax') || errMsg.includes('vector')) {",
									"        console.error('[BUG DETECTED] Double-bracket bug in Group 1 query.');",
									"        console.error('[FIX] Check jobChat.services.js - embedding::text handling');",
									"        pm.test('CRITICAL: Vector syntax error (double brackets) (Group 1)', function () {",
									"            pm.expect.fail('PostgreSQL vector syntax error. Fix embedding string format.');",
									"        });",
									"    }",
									"    ",
									"    if (errMsg.includes('nan') || errMsg.includes('is nan') || errMsg.includes('isnan')) {",
									"        console.error('[BUG DETECTED] NaN in similarity computation.');",
									"        pm.test('CRITICAL: NaN bug detected in vector math (Group 1)', function () {",
									"            pm.expect.fail('NaN in similarity. Check cosineSimilarity array validation.');",
									"        });",
