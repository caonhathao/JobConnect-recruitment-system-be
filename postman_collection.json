		{
			"name": "📄 Resume Management",
			"description": "Upload, list, set default, and delete CVs. Resume IDs are auto-saved for use in chat requests.",
			"item": [
				{
					"name": "Upload CV (PDF)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// =============================================",
									"// Status Code Check (201 = accepted for processing)",
									"// =============================================",
									"pm.test('Status 201 - Upload accepted', function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"// =============================================",
									"// Validate Upload Response",
									"// =============================================",
									"pm.test('Upload response has valid structure', function () {",
									"    const json = pm.response.json();",
									"    pm.expect(json.status).to.eql('success');",
									"    pm.expect(json).to.have.property('data');",
									"    pm.expect(json.data).to.have.property('id');",
									"    pm.expect(json.data).to.have.property('fileUrl');",
									"    pm.expect(json.data).to.have.property('isDefault');",
									"    pm.expect(json.data).to.have.property('createdAt');",
									"});",
									"",
									"// =============================================",
									"// Save resumeId for downstream requests",
									"// =============================================",
									"const json = pm.response.json();",
									"if (json.data && json.data.id) {",
									"    pm.environment.set('resumeId', json.data.id);",
									"    console.log('[Upload CV] resumeId saved: ' + json.data.id);",
									"    console.log('[Upload CV] vectorStatus is PENDING. Wait for background processing...');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{accessToken}}"
							}
						],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "cv",
									"type": "file",
									"src": "",
									"description": "PDF file (max 5MB). After upload, the system asynchronously extracts text, chunks, and embeds it."
								}
							]
						},
						"url": {
							"raw": "{{baseUrl}}/api/resumes/upload",
							"host": ["{{baseUrl}}"],
							"path": ["api", "resumes", "upload"]
						}
					}
				},
				{
					"name": "List My CVs",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// =============================================",
									"// Status Code Check",
									"// =============================================",
									"pm.test('Status 200 - OK', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"// =============================================",
									"// Validate List Response",
									"// =============================================",
									"pm.test('Response is an array of resumes', function () {",
									"    const json = pm.response.json();",
									"    pm.expect(json.status).to.eql('success');",
									"    pm.expect(json.data).to.be.an('array');",
									"    if (json.data.length > 0) {",
									"        pm.expect(json.data[0]).to.have.property('id');",
									"        pm.expect(json.data[0]).to.have.property('title');",
									"        pm.expect(json.data[0]).to.have.property('fileUrl');",
									"        pm.expect(json.data[0]).to.have.property('isDefault');",
									"    }",
									"});",
									"",
									"// =============================================",
									"// Check vectorStatus polling hint",
									"// =============================================",
									"pm.test('Hint: Check vectorStatus in DB', function () {",
									"    console.log('[List CVs] To check vector completion, use Get CV Status endpoint or check DB.');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{accessToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/resumes",
							"host": ["{{baseUrl}}"],
							"path": ["api", "resumes"]
						}
					}
				},
				{
					"name": "Get CV Vector Status",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// =============================================",
									"// This endpoint checks vectorStatus by querying",
									"// the resumes list and filtering for the saved resumeId.",
									"// =============================================",
									"pm.test('Status 200 - OK', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"const json = pm.response.json();",
									"const resumeId = pm.environment.get('resumeId');",
									"",
									"if (json.data && resumeId) {",
									"    const target = json.data.find(r => r.id === resumeId);",
									"    if (target) {",
									"        console.log('[Status] Resume found in list');",
									"        console.log('[Status] NOTE: vectorStatus is NOT exposed in GET /api/resumes.');",
									"        console.log('[Status] Check database directly or wait ~10s after upload.');",
									"    } else {",
									"        console.warn('[Status] Resume ID ' + resumeId + ' not found in list.');",
									"    }",
									"}",
									"",
									"// =============================================",
									"// CRITICAL LOGIC CHECK: NaN / Double Brackets",
									"// If this endpoint returned 500, flag it immediately.",
									"// =============================================",
									"if (pm.response.code === 500) {",
									"    const errJson = pm.response.json();",
									"    const errMsg = (errJson.error || errJson.message || '').toLowerCase();",
									"    ",
									"    if (errMsg.includes('nan') || errMsg.includes('is nan')) {",
									"        console.error('[BUG DETECTED] NaN error in vector computation.');",
									"        console.error('[BUG] Check cosineSimilarity or JSON.parse in jobChat.services.js');",
									"        pm.test('CRITICAL: NaN bug detected!', function () {",
									"            pm.expect.fail('NaN detected. Fix cosineSimilarity input validation.');",
									"        });",
									"    }",
									"    ",
									"    if (errMsg.includes('input syntax') || errMsg.includes('vector')) {",
									"        console.error('[BUG DETECTED] Vector format error - likely double brackets issue.');",
									"        console.error('[BUG] Check jobChat.services.js:398 - v.embedding wrapping.');",
									"        pm.test('CRITICAL: Double-bracket bug detected!', function () {",
									"            pm.expect.fail('Vector format error. Fix [${v.embedding}] → v.embedding');",
									"        });",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{accessToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/resumes",
							"host": ["{{baseUrl}}"],
							"path": ["api", "resumes"]
						}
					}
				},
				{
