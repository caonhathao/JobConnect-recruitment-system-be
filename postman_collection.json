							"raw": "{\n  \"fullName\": \"Admin Corp\",\n  \"email\": \"recruiter@gmail.com\",\n  \"phone\": \"0901234568\",\n  \"password\": \"123456\",\n  \"companyName\": \"ABC Corp\",\n  \"address\": \"Hồ Chí Minh\"\n}"
						},
