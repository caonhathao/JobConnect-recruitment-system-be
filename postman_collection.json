		{
			"name": "🤖 RAG Chat (Core Feature)",
			"description": "AI-powered job assistant using RAG pipeline: intent classification → vector search → Ollama Qwen2.5 response.\n\nAll chat endpoints return `messageResponse` format: `{ type, message, data? }`\n- On SUCCESS: `{ type: \"SUCCESS\", message: \"<AI answer>\" }`\n- On FAILED: `{ type: \"FAILED\", message: \"<error description>\" }`\n\nThe data field is only present for job-suggestions (list of jobs).",
			"item": [
				{
					"name": "Chat - Group 1: Job Search",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status 200 - OK', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response time < 15000ms (AI generation)', function () {",
									"    pm.expect(pm.response.responseTime).to.be.below(15000);",
									"});",
									"",
									"pm.test('AI response uses messageResponse format', function () {",
									"    const json = pm.response.json();",
									"    pm.expect(json).to.have.property('type');",
									"    pm.expect(json).to.have.property('message');",
									"    pm.expect(json.type).to.eql('SUCCESS');",
									"    pm.expect(json.message).to.not.be.null;",
									"    pm.expect(json.message).to.not.be.empty;",
									"    console.log('[Chat] AI reply: ' + json.message.substring(0, 200) + '...');",
									"});",
									"",
									"if (pm.response.code === 500) {",
									"    const errMsg = JSON.stringify(pm.response.json()).toLowerCase();",
									"    if (errMsg.includes('input syntax') || errMsg.includes('vector'))",
									"        console.error('[BUG] Vector syntax error in Group 1 query.');",
									"    if (errMsg.includes('nan'))",
									"        console.error('[BUG] NaN in similarity computation.');",
									"    if (errMsg.includes('ollama') || errMsg.includes('econnrefused'))",
									"        console.error('[INFRA] Ollama not running. Start: ollama run qwen2.5:3b');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"question\": \"Tôi muốn tìm việc làm NodeJS ở Hồ Chí Minh\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/chat/chat",
							"host": ["{{baseUrl}}"],
							"path": ["api", "chat", "chat"]
						}
					}
				},
				{
					"name": "Chat - Group 2: CV-Based Job Search",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status 200 - OK', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response time < 20000ms (AI + vector search)', function () {",
									"    pm.expect(pm.response.responseTime).to.be.below(20000);",
									"});",
									"",
									"pm.test('AI response uses messageResponse format', function () {",
									"    const json = pm.response.json();",
									"    pm.expect(json).to.have.property('type');",
									"    pm.expect(json).to.have.property('message');",
									"    console.log('[CV Search] Response: ' + (json.message || '').substring(0, 200) + '...');",
									"});",
									"",
									"const json = pm.response.json();",
